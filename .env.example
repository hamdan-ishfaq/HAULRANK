DJANGO_SECRET_KEY=change-me-in-production
# Local bare runserver default. Docker Compose overrides to "0".
# Railway/Render: set DJANGO_DEBUG=0 and use config.settings.production (DEBUG=False hard).
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Local without Docker (Docker Compose overrides DB + Redis):
DATABASE_URL=sqlite:///db.sqlite3
REDIS_URL=
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# LLM — Explain + Copilot
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional diesel (fallback $3.80 if empty): https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# Optional OpenWeather backup (Open-Meteo is primary, no key):
OPENWEATHER_API_KEY=
# Force a weather chip for demos when weather is calm:
WEATHER_DEMO=0

# Optional crash tracing (Render production only):
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.2
